<Window x:Class="USS.Desktop.App.ThemeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="660"
        Height="760"
        MinWidth="600"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PageBrush}"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="DialogCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button" BasedOn="{StaticResource AppPrimaryButtonStyle}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="DialogSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AppSecondaryButtonStyle}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="DialogInputStyle" TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}">
            <Setter Property="Height" Value="36" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontFamily="Bahnschrift SemiCondensed"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="{DynamicResource InkBrush}"
                   Text="{Binding WindowTitle}" />

        <TextBlock Grid.Row="1"
                   Margin="0,10,0,16"
                   Foreground="{DynamicResource MutedInkBrush}"
                   TextWrapping="Wrap"
                   Text="{Binding DescriptionText}" />

        <Border Grid.Row="2" Style="{StaticResource DialogCardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="92" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource InkBrush}"
                                           Text="{Binding DisplayName}" />

                                <Border Grid.Column="1"
                                        Width="28"
                                        Height="28"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        CornerRadius="7"
                                        BorderBrush="{DynamicResource CardStrokeBrush}"
                                        BorderThickness="1"
                                        Background="{Binding PreviewBrush}" />

                                <TextBox Grid.Column="2"
                                         Margin="0,0,12,0"
                                         Style="{StaticResource DialogInputStyle}"
                                         Text="{Binding HexValue, UpdateSourceTrigger=PropertyChanged}" />

                                <Button Grid.Column="3"
                                        Style="{StaticResource DialogSecondaryButtonStyle}"
                                        Margin="0"
                                        Content="{Binding DataContext.PickButtonText, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Tag="{Binding}"
                                        Click="OnPickColorClick" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <WrapPanel Grid.Column="0">
                <Button Style="{StaticResource DialogSecondaryButtonStyle}"
                        Content="{Binding ResetLightButtonText}"
                        Click="OnResetLightClick" />
                <Button Style="{StaticResource DialogSecondaryButtonStyle}"
                        Content="{Binding ResetDarkButtonText}"
                        Click="OnResetDarkClick" />
            </WrapPanel>

            <WrapPanel Grid.Column="1">
                <Button Style="{StaticResource DialogSecondaryButtonStyle}"
                        Content="{Binding CancelButtonText}"
                        Click="OnCancelClick" />
                <Button Style="{StaticResource DialogButtonStyle}"
                        Margin="0"
                        Content="{Binding SaveButtonText}"
                        Click="OnSaveClick" />
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
