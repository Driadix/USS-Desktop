<Window x:Class="USS.Desktop.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="USS Desktop"
        Width="1440"
        Height="920"
        MinWidth="1220"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#F2ECE2">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#F2ECE2" />
        <SolidColorBrush x:Key="InkBrush" Color="#18212B" />
        <SolidColorBrush x:Key="MutedInkBrush" Color="#5B6672" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFDF9" />
        <SolidColorBrush x:Key="CardStrokeBrush" Color="#DCCFBC" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#C5642F" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#94441C" />
        <SolidColorBrush x:Key="AccentBrush" Color="#233647" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#55735A" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#F8F1E8" />
            <Setter Property="BorderBrush" Value="{StaticResource CardStrokeBrush}" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{StaticResource CardStrokeBrush}" />
            <Setter Property="Background" Value="#FFFDF9" />
        </Style>

        <Style x:Key="ReadOnlyBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputStyle}">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Background" Value="#F8F5EF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="24"
                    Padding="26"
                    Background="{StaticResource AccentBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontFamily="Bahnschrift SemiCondensed"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#FFF7EF"
                                   Text="USS Desktop" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="14"
                                   Foreground="#D6E1EA"
                                   Text="Deterministic Arduino compile and flash workflows for non-IDE operators." />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#1AFFFFFF"
                            CornerRadius="16"
                            Padding="18,12">
                        <StackPanel>
                            <TextBlock Foreground="#D6E1EA"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="CURRENT STATUS" />
                            <TextBlock Margin="0,4,0,0"
                                       Width="320"
                                       TextWrapping="Wrap"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="{Binding ProjectStatus}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="390" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Project" />

                            <WrapPanel Margin="0,0,0,8">
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Width="150"
                                        Content="Open Folder"
                                        Command="{Binding OpenFolderCommand}" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Width="120"
                                        Content="Refresh"
                                        Command="{Binding RefreshCommand}" />
                            </WrapPanel>

                            <TextBlock Style="{StaticResource CaptionStyle}" Text="Folder" />
                            <TextBox Style="{StaticResource ReadOnlyBoxStyle}"
                                     Text="{Binding SelectedProjectPath}"
                                     TextWrapping="Wrap" />

                            <TextBlock Style="{StaticResource CaptionStyle}" Text="Detection" />
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}"
                                       Text="{Binding DiscoveryLabel}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{StaticResource MutedInkBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ProjectStatus}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding ShowImportPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Import / Bootstrap" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"
                                       Text="{Binding ImportHint}" />

                            <TextBlock Style="{StaticResource CaptionStyle}" Text="Project Name" />
                            <TextBox Style="{StaticResource InputStyle}"
                                     Text="{Binding ImportProjectName, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Visibility="{Binding ShowBootstrapFields, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Profile Name" />
                                <TextBox Style="{StaticResource InputStyle}"
                                         Text="{Binding BootstrapProfileName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="FQBN" />
                                <TextBox Style="{StaticResource InputStyle}"
                                         Text="{Binding BootstrapFqbn, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Detected Family" />
                                <TextBox Style="{StaticResource ReadOnlyBoxStyle}"
                                         Text="{Binding BootstrapFamily}" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Platform Identifier" />
                                <TextBox Style="{StaticResource InputStyle}"
                                         Text="{Binding BootstrapPlatformIdentifier, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Platform Version" />
                                <TextBox Style="{StaticResource InputStyle}"
                                         Text="{Binding BootstrapPlatformVersion, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Platform Index URL" />
                                <TextBox Style="{StaticResource InputStyle}"
                                         Text="{Binding BootstrapPlatformIndexUrl, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Pinned Libraries, one per line" />
                                <TextBox Style="{StaticResource InputStyle}"
                                         Height="94"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding BootstrapLibraries, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,4,0,0"
                                    Width="210"
                                    Content="{Binding ImportActionLabel}"
                                    Command="{Binding ImportCommand}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recent Projects" />
                            <ItemsControl ItemsSource="{Binding RecentProjects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,0,0,8"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                       Visibility="{Binding ShowRecentProjectsEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Text="Use Open Folder to populate recent projects." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="0.85*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Actions" />
                                <WrapPanel Margin="0,0,0,10">
                                    <Button Style="{StaticResource PrimaryButtonStyle}"
                                            Width="140"
                                            Content="Compile"
                                            Command="{Binding CompileCommand}" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                            Width="140"
                                            Content="Flash"
                                            Command="{Binding UploadCommand}" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                            Width="170"
                                            Content="Compile + Flash"
                                            Command="{Binding CompileAndUploadCommand}" />
                                </WrapPanel>

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Upload Port Override" />
                                <ComboBox Margin="0,0,0,10"
                                          Padding="8"
                                          Height="38"
                                          IsEditable="True"
                                          ItemsSource="{Binding AvailablePorts}"
                                          Text="{Binding SelectedPort, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                           Text="Leave the port blank to let USS auto-select a single connected COM port." />

                                <Border Margin="0,18,0,0"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="#F8F1E8"
                                        BorderBrush="{StaticResource CardStrokeBrush}"
                                        BorderThickness="1">
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="{Binding ProjectStatus}" />
                                </Border>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Padding="16"
                                    CornerRadius="16"
                                    Background="#F6F8FA"
                                    BorderBrush="{StaticResource CardStrokeBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Diagnostics" />
                                    <TextBox Style="{StaticResource ReadOnlyBoxStyle}"
                                             AcceptsReturn="True"
                                             Text="{Binding DiagnosticsSummary}"
                                             TextWrapping="Wrap" />
                                    <TextBlock Margin="0,18,0,0"
                                               Foreground="{StaticResource SuccessBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding IsBusy, StringFormat=Busy: {0}}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Project Details" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Name" />
                                <TextBox Style="{StaticResource ReadOnlyBoxStyle}" Text="{Binding ProjectName}" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Kind" />
                                <TextBox Style="{StaticResource ReadOnlyBoxStyle}" Text="{Binding ProjectKind}" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Family" />
                                <TextBox Style="{StaticResource ReadOnlyBoxStyle}" Text="{Binding ProjectFamily}" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="Active Profile" />
                                <TextBox Style="{StaticResource ReadOnlyBoxStyle}" Text="{Binding ActiveProfile}" />

                                <TextBlock Style="{StaticResource CaptionStyle}" Text="FQBN" />
                                <TextBox Style="{StaticResource ReadOnlyBoxStyle}"
                                         Text="{Binding Fqbn}"
                                         TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Validation" />
                                <ItemsControl ItemsSource="{Binding Issues}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="12"
                                                    CornerRadius="12"
                                                    Background="#FBF7F1"
                                                    BorderBrush="{StaticResource CardStrokeBrush}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Run Log" />
                            <TextBox Height="300"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Text="{Binding SessionLog}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
