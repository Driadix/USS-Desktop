<Window x:Class="USS.Desktop.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="USS Desktop"
        Width="1460"
        Height="920"
        MinWidth="1220"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PageBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource MutedInkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AppPrimaryButtonStyle}">
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AppSecondaryButtonStyle}">
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource AppDangerButtonStyle}">
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SurfaceBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="OverlayIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Foreground" Value="{DynamicResource OverlayArrowBrush}" />
            <Setter Property="Opacity" Value="0.84" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource OverlayArrowHoverBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OperationBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource StatusIdleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource StatusActiveBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="18"
                CornerRadius="20"
                Background="{DynamicResource ChromeBrush}"
                BorderBrush="{DynamicResource ChromeStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock FontFamily="Bahnschrift SemiCondensed"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AccentTextBrush}"
                           VerticalAlignment="Center"
                           Text="USS Desktop" />

                <Border Grid.Column="1"
                        Margin="18,0"
                        Padding="16,14"
                        CornerRadius="14"
                        Background="{DynamicResource ChromeSurfaceBrush}"
                        BorderBrush="{DynamicResource ChromeStrokeBrush}"
                        BorderThickness="1">
                    <StackPanel MaxWidth="560">
                        <TextBlock Foreground="{DynamicResource AccentTextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="{Binding Localization[Header.CurrentStatus]}" />
                        <TextBlock Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="{Binding ProjectStatus}" />
                    </StackPanel>
                </Border>

                <Grid Grid.Column="2" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" MinWidth="130">
                        <TextBlock Style="{StaticResource CaptionStyle}"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   Text="{Binding Localization[Settings.LanguageLabel]}" />
                        <ComboBox Width="132"
                                  Style="{StaticResource AppComboBoxStyle}"
                                  ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  DisplayMemberPath="Label" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" MinWidth="138">
                        <TextBlock Style="{StaticResource CaptionStyle}"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   Text="{Binding Localization[Settings.ThemeLabel]}" />
                        <ComboBox Width="138"
                                  Style="{StaticResource AppComboBoxStyle}"
                                  ItemsSource="{Binding ThemeModeOptions}"
                                  SelectedItem="{Binding SelectedThemeMode}"
                                  DisplayMemberPath="Label" />
                    </StackPanel>

                    <Button Grid.Column="4"
                            Width="154"
                            Margin="0,18,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="{Binding Localization[Settings.CustomizeTheme]}"
                            Command="{Binding OpenThemeEditorCommand}" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="{Binding Localization[Project.Section]}" />

                                <WrapPanel Grid.Column="1">
                                    <Button Width="138"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Content="{Binding Localization[Project.OpenFolder]}"
                                            Command="{Binding OpenFolderCommand}" />
                                    <Button Width="108"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="{Binding Localization[Project.Refresh]}"
                                            Command="{Binding RefreshCommand}" />
                                </WrapPanel>
                            </Grid>

                            <StackPanel Grid.Row="1">
                                <TextBlock Style="{StaticResource CaptionStyle}"
                                           Text="{Binding Localization[Project.Folder]}" />
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="126" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource SurfaceBorderStyle}" Margin="0">
                                        <TextBlock TextWrapping="Wrap" Text="{Binding SelectedProjectPath}" />
                                    </Border>
                                    <Button Grid.Column="2"
                                            Height="40"
                                            Margin="0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="{Binding Localization[Project.OpenInExplorer]}"
                                            Command="{Binding OpenProjectLocationCommand}" />
                                </Grid>

                                <TextBlock Style="{StaticResource CaptionStyle}"
                                           Text="{Binding Localization[Project.Detection]}" />
                                <Border Style="{StaticResource SurfaceBorderStyle}">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding DiscoveryLabel}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{DynamicResource MutedInkBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding ProjectStatus}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Row="2" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SurfaceBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Project.NameLabel]}" />
                                        <TextBlock FontWeight="SemiBold" Text="{Binding ProjectName}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource SurfaceBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Project.KindLabel]}" />
                                        <TextBlock FontWeight="SemiBold" Text="{Binding ProjectKind}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SurfaceBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Project.FamilyLabel]}" />
                                        <TextBlock FontWeight="SemiBold" Text="{Binding ProjectFamily}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource SurfaceBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Project.ActiveProfileLabel]}" />
                                        <TextBlock FontWeight="SemiBold" Text="{Binding ActiveProfile}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource SurfaceBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Project.FqbnLabel]}" />
                                        <TextBlock FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding Fqbn}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="{Binding Localization[Health.Section]}" />

                            <Button Grid.Column="1"
                                    Width="122"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Visibility="{Binding HasLockFile, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Content="{Binding Localization[Health.DeleteLock]}"
                                    Command="{Binding DeleteLockCommand}" />

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                                <TextBlock Margin="0,0,0,10"
                                           Foreground="{DynamicResource MutedInkBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasLockFile, Converter={StaticResource BooleanToVisibilityConverter}}"
                                           Text="{Binding LockFilePath}" />
                                <ItemsControl ItemsSource="{Binding Issues}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SurfaceBorderStyle}">
                                                <TextBlock TextWrapping="Wrap" Text="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding ShowImportPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Localization[Import.Section]}" />
                            <TextBlock Margin="0,0,0,12"
                                       Foreground="{DynamicResource MutedInkBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ImportHint}" />
                            <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Import.ProjectName]}" />
                            <TextBox Style="{StaticResource InputStyle}" Text="{Binding ImportProjectName, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Visibility="{Binding ShowBootstrapFields, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Import.ProfileName]}" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding BootstrapProfileName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Import.Fqbn]}" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding BootstrapFqbn, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Import.DetectedFamily]}" />
                                <Border Style="{StaticResource SurfaceBorderStyle}">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding BootstrapFamily}" />
                                </Border>
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Import.PlatformIdentifier]}" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding BootstrapPlatformIdentifier, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Import.PlatformVersion]}" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding BootstrapPlatformVersion, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Import.PlatformIndexUrl]}" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding BootstrapPlatformIndexUrl, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource CaptionStyle}" Text="{Binding Localization[Import.PinnedLibraries]}" />
                                <TextBox Style="{StaticResource InputStyle}"
                                         Height="94"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding BootstrapLibraries, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <Button Width="220"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="{Binding ImportActionLabel}"
                                    Command="{Binding ImportCommand}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Localization[Recent.Section]}" />
                            <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding RecentProjects}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                    HorizontalContentAlignment="Stretch"
                                                    Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock Foreground="{DynamicResource MutedInkBrush}"
                                       Visibility="{Binding ShowRecentProjectsEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Text="{Binding Localization[Recent.Empty]}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Margin="0"
                                           Text="{Binding Localization[Actions.Section]}" />

                                <Border Grid.Column="1" Style="{StaticResource OperationBadgeStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Foreground="{DynamicResource MutedInkBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Localization[Actions.ActivityLabel]}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   Foreground="{DynamicResource InkBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ActiveOperationLabel}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Height="52" Margin="0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding CompileCommand}">
                                    <TextBlock Text="{Binding Localization[Actions.Compile]}" TextWrapping="Wrap" TextAlignment="Center" />
                                </Button>
                                <Button Grid.Column="2" Height="52" Margin="0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding UploadCommand}">
                                    <TextBlock Text="{Binding Localization[Actions.Flash]}" TextWrapping="Wrap" TextAlignment="Center" />
                                </Button>
                                <Button Grid.Column="4" Height="52" Margin="0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CompileAndUploadCommand}">
                                    <TextBlock Text="{Binding Localization[Actions.CompileAndFlash]}" TextWrapping="Wrap" TextAlignment="Center" />
                                </Button>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Style="{StaticResource CaptionStyle}"
                                           Text="{Binding Localization[Actions.UploadPort]}" />

                                <ComboBox Grid.Row="1"
                                          Grid.Column="0"
                                          Style="{StaticResource AppComboBoxStyle}"
                                          IsEditable="True"
                                          ItemsSource="{Binding AvailablePorts}"
                                          Text="{Binding SelectedPort, UpdateSourceTrigger=PropertyChanged}" />

                                <Button Grid.Row="1"
                                        Grid.Column="2"
                                        Height="38"
                                        Margin="0"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Content="{Binding Localization[Actions.Stop]}"
                                        Command="{Binding StopCommand}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource MutedInkBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding Localization[Actions.UploadPortHint]}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Localization[Diagnostics.Section]}" />
                            <TextBox Style="{StaticResource InputStyle}"
                                     Height="152"
                                     Margin="0"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     TextWrapping="Wrap"
                                     Text="{Binding DiagnosticsSummary}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Localization[Log.Section]}" />
                            <Button Grid.Column="1"
                                    Width="104"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="{Binding Localization[Log.Clear]}"
                                    Command="{Binding ClearLogCommand}" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <TextBox x:Name="SessionLogTextBox"
                                     Margin="0,2,0,0"
                                     Padding="12,10"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Foreground="{DynamicResource InkBrush}"
                                     Background="{DynamicResource LogBackgroundBrush}"
                                     BorderBrush="{DynamicResource LogBorderBrush}"
                                     BorderThickness="1"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Text="{Binding SessionLog}" />
                            <Button x:Name="FollowLogButton"
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,18,18"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Panel.ZIndex="1"
                                    Style="{StaticResource OverlayIconButtonStyle}"
                                    ToolTip="{Binding Localization[Log.FollowTooltip]}"
                                    Visibility="Collapsed"
                                    Content="↓"
                                    Click="OnFollowLogButtonClick" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
